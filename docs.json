{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "HG.Cash",
  "colors": {
    "primary": "#16A34A",
    "light": "#07C983",
    "dark": "#15803D"
  },
  "favicon": "/favicon.ico",
  "navigation": {
    "languages": [
      {
        "language": "en",
        "default": true,
        "navbar": {
          "primary": {
            "type": "button",
            "label": "Dashboard",
            "href": "https://hg.cash"
          }
        },
        "tabs": [
          {
            "tab": "Documentation",
            "pages": [
              "introduction",
              {
                "group": "Settlement",
                "pages": [
                  "settlement/introduction",
                  "settlement/withdrawals",
                  "settlement/spot",
                  "exchange/usdt-withdrawals"
                ]
              },
              {
                "group": "Checkouts",
                "pages": [
                  "checkouts/introduction",
                  "checkouts/create",
                  "checkouts/validate",
                  "checkouts/reconcile"
                ]
              },
              {
                "group": "Claims",
                "pages": [
                  "claims/introduction"
                ]
              },
              {
                "group": "Developers",
                "pages": [
                  "developers/introduction",
                  "developers/receiving-webhooks",
                  "developers/webhook-delivery-and-monitoring"
                ]
              }
            ]
          },
          {
            "tab": "Countries",
            "pages": [
              "countries/introduction",
              {
                "group": "Argentina",
                "pages": ["countries/argentina/bank-transfers"]
              },
              {
                "group": "Chile",
                "pages": ["countries/chile/cash-in", "countries/chile/payouts"]
              },
              {
                "group": "Brazil",
                "pages": ["countries/brazil/pix-cash-in", "countries/brazil/pix-payouts"]
              },
              {
                "group": "Bolivia",
                "pages": ["countries/bolivia/qr-cash-in", "countries/bolivia/payouts"]
              }
            ]
          },
          {
            "tab": "API reference",
            "groups": [
              {
                "group": "API documentation",
                "openapi": {
                  "source": "api-reference/openapi.yaml",
                  "directory": "api-reference"
                }
              }
            ]
          }
        ]
      },
